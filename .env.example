# ═══════════════════════════════════════════════════════════════════════
# Trading Bot V2 — Environment Variables
# ═══════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#   nano .env
#
# NEVER commit .env to git — it contains secrets!
# ═══════════════════════════════════════════════════════════════════════

# ── MT5 Connection ───────────────────────────────────────────────────
# Auto-set by docker-compose.ec2.yml — only change if running standalone
# MT5_HOST=metatrader5
# MT5_PORT=8001

# ── Telegram User Account (for reading signal channels) ─────────────
# Required for Telegram signal ingestion
# Get API credentials from: https://my.telegram.org
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE=+1234567890

# ── Claude AI (for signal parsing + Claude pre-trade filter) ────────
# Required. Get from: https://console.anthropic.com
# Used by: Telegram signal parser + ClaudeSignalFilter
# Cost: ~$0.01/day at 100 trades (Haiku model)
ANTHROPIC_API_KEY=

# ── Notifications (optional but recommended) ────────────────────────
# Slack webhook for trade alerts and daily summaries
SLACK_WEBHOOK_URL=

# Telegram bot for mobile notifications (separate from listener above)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# ── Config Overlay ───────────────────────────────────────────────────
# Loads config/<name>.yaml on top of base.yaml
# Set to "fundingpips" for prop firm trading
CONFIG_OVERLAY=fundingpips
